  "_lookup_logic": {
    "description": "How the Kg calculator resolves a part to a material entry",
    "plancha_key": "Match on tipo=Plancha + calidad + esp_mm + terminacion (if known). If terminacion unknown, use the cheapest matching esp_mm entry. Flag as assumption.",
    "perfil_key": "Match on tipo=Perfil + seccion_code from part A field. Kg = L_m × kg_por_metro[entry]. If kg_por_metro is null, flag part as kg_manual_requerido.",
    "tubo_key": "Match on tipo=Tubo + diametro_nominal or diametro_ext_mm. Kg = π × d_ext × esp × L × 7.93e-6. Or use kg_por_metro lookup if available.",
    "key_miss": "If no match: flag part as precio_manual_requerido. Do NOT assume 0 or use fallback price."
  }
}
