  "driver_thresholds": {
    "G": {
      "description": "Área de planta (L × W) en mm²",
      "breakpoints_mm2": [
        1000000,
        1700000
      ],
      "scores": {
        "1": {
          "label": "Pequeño",
          "condition": "area < 500000"
        },
        "2": {
          "label": "Mediano",
          "condition": "500000 <= area < 1500000"
        },
        "3": {
          "label": "Grande",
          "condition": "area >= 1500000"
        }
      }
    },
    "D": {
      "description": "Espesor de lámina en mm",
      "breakpoints_mm": [
        1.5,
        2.0
      ],
      "scores": {
        "1": {
          "label": "Delgado",
          "condition": "espesor <= 1.5"
        },
        "2": {
          "label": "Normal",
          "condition": "1.5 < espesor <= 2.0"
        },
        "3": {
          "label": "Grueso",
          "condition": "espesor > 2.0"
        }
      }
    },
    "C": {
      "description": "Conteo de componentes principales",
      "breakpoints": [
        3,
        7
      ],
      "scores": {
        "1": {
          "label": "Pocos",
          "condition": "count <= 3"
        },
        "2": {
          "label": "Moderado",
          "condition": "3 < count <= 7"
        },
        "3": {
          "label": "Muchos",
          "condition": "count > 7"
        }
      }
    }
  },
